# ── Apify ────────────────────────────────────────────────────────────────────
APIFY_TOKEN=your_apify_token_here

# ── GitHub Gist (state persistence across GitHub Actions runs) ───────────────
# GITHUB_TOKEN is auto-injected in Actions — only needed for local runs
GITHUB_TOKEN=your_github_personal_access_token
# Leave blank on first run — the script will print the created Gist ID
# Then add it as a secret: Settings → Secrets → GIST_ID
GIST_ID=

# ── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=alerts@youremail.com

# ── Alert thresholds (overridden per session in code, these are fallback) ────
PCT_CHANGE_THRESHOLD=3.0
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
COOLDOWN_SEC=300
